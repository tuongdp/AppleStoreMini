{
  "name": "applestore",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:api": "cross-env PLAYWRIGHT_SKIP_WEBSERVER=true playwright test tests/api --project=api",
    "test:fullstack": "node tests/scripts/run-fullstack-tests.mjs",
    "test:regression": "cross-env TEST_SUITE=regression playwright test",
    "test:visual": "cross-env TEST_VISUAL=true playwright test tests/e2e --grep @visual",
    "test:report": "playwright show-report",
    "test:install": "playwright install --with-deps",
    "test:ci": "playwright test --reporter=line,html,junit",
    "testsprite:mcp": "npx @testsprite/testsprite-mcp@latest",
    "testsprite:doctor": "npx @testsprite/testsprite-mcp@latest --help"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
